{
  "info": {
    "name": "flash-sale-system — Step 11",
    "description": "Tests for OrderExpiryScheduler + GET /api/orders [ADMIN].\n\nREQUIRED SETUP before Folders 2-4:\n  Set app.order.pending-timeout-minutes=0 in application.yml and restart the app.\n  This makes every PENDING order expire immediately on the next scheduler tick (~60s).\n\nREVERT after all tests:\n  Restore app.order.pending-timeout-minutes=15 and restart.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "0 — Pre-flight: Auth + Stock Snapshot",
      "item": [
        {
          "name": "User Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has accessToken', () => pm.expect(json.accessToken).to.be.a('string'));",
                  "pm.environment.set('userToken', json.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{userUsername}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has accessToken', () => pm.expect(json.accessToken).to.be.a('string'));",
                  "pm.environment.set('adminToken', json.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Snapshot Product Stock",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has availableStock', () => pm.expect(json.availableStock).to.be.a('number'));",
                  "pm.environment.set('step11InitialStock', json.availableStock);",
                  "console.log('Initial stock:', json.availableStock);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api", "products", "{{productId}}"] }
          }
        },
        {
          "name": "Restock Product (ensure stock >= 5)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.environment.set('step11InitialStock', json.availableStock);",
                  "console.log('Stock after restock:', json.availableStock);"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"delta\": 5,\n  \"reason\": \"restock\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/products/{{productId}}/inventory", "host": ["{{baseUrl}}"], "path": ["api", "products", "{{productId}}", "inventory"] }
          }
        },
        {
          "name": "Clear Cart",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 or 204', () => pm.expect(pm.response.code).to.be.oneOf([200, 204]));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/cart", "host": ["{{baseUrl}}"], "path": ["api", "cart"] },
            "description": "Check cart — manually clear any leftover items if needed before running Folder 2."
          }
        }
      ]
    },
    {
      "name": "1 — Admin: GET /api/orders",
      "item": [
        {
          "name": "Admin gets all orders — 200",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has paginated content', () => {",
                  "  pm.expect(json).to.have.property('content');",
                  "  pm.expect(json).to.have.property('totalElements');",
                  "  pm.expect(json).to.have.property('totalPages');",
                  "});",
                  "pm.test('content is an array', () => pm.expect(json.content).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders", "host": ["{{baseUrl}}"], "path": ["api", "orders"] }
          }
        },
        {
          "name": "User gets all orders — 403 (forbidden)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders", "host": ["{{baseUrl}}"], "path": ["api", "orders"] }
          }
        },
        {
          "name": "Admin gets all orders — sorted by createdAt desc",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Page size is 5', () => pm.expect(json.content.length).to.be.at.most(5));",
                  "pm.test('Orders are sorted newest first', () => {",
                  "  const dates = json.content.map(o => new Date(o.createdAt).getTime());",
                  "  for (let i = 1; i < dates.length; i++) {",
                  "    pm.expect(dates[i - 1]).to.be.at.least(dates[i]);",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/orders?page=0&size=5&sort=createdAt,desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "5" },
                { "key": "sort", "value": "createdAt,desc" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "2 — Expiry Job: Cancels Abandoned Order + Restores Stock",
      "description": "SETUP REQUIRED: set app.order.pending-timeout-minutes=0 in application.yml and restart.\nRun requests 1-3, then WAIT 60-90 seconds, then run requests 4-6.",
      "item": [
        {
          "name": "2-1 Add item to cart (qty=1)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('cartItem has id', () => pm.expect(json.cartItem).to.have.property('id'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": {{productId}},\n  \"quantity\": 1\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/cart/items", "host": ["{{baseUrl}}"], "path": ["api", "cart", "items"] }
          }
        },
        {
          "name": "2-2 Checkout — creates PENDING order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Order status is PENDING', () => pm.expect(json.status).to.equal('PENDING'));",
                  "pm.test('Has order id', () => pm.expect(json.id).to.be.a('number'));",
                  "pm.environment.set('step11ExpiryOrderId', json.id);",
                  "console.log('Expiry order id:', json.id, '— now WAIT 60-90s before running 2-4');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders/checkout", "host": ["{{baseUrl}}"], "path": ["api", "orders", "checkout"] }
          }
        },
        {
          "name": "2-3 Verify order is PENDING (immediately)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Order status is PENDING', () => pm.expect(json.status).to.equal('PENDING'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders/{{step11ExpiryOrderId}}", "host": ["{{baseUrl}}"], "path": ["api", "orders", "{{step11ExpiryOrderId}}"] }
          }
        },
        {
          "name": "⏳ WAIT 60-90s — then run 2-4, 2-5, 2-6",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// This request intentionally hits a non-existent path to act as a pause reminder.",
                  "// Postman will show a 404 — that is expected.",
                  "// Check Spring Boot logs for: [Expiry] Cancelled orderId=X",
                  "console.log('>>> PAUSE: wait 60-90 seconds for the expiry scheduler to fire, then continue.');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 404 is expected — this is just a wait/reminder step.",
                  "console.log('>>> If you have waited 60-90s, continue with request 2-4.');"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/wait-reminder-not-a-real-endpoint", "host": ["{{baseUrl}}"], "path": ["wait-reminder-not-a-real-endpoint"] }
          }
        },
        {
          "name": "2-4 Verify order is CANCELLED (after scheduler fires)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Order status is CANCELLED', () => pm.expect(json.status).to.equal('CANCELLED'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders/{{step11ExpiryOrderId}}", "host": ["{{baseUrl}}"], "path": ["api", "orders", "{{step11ExpiryOrderId}}"] }
          }
        },
        {
          "name": "2-5 Verify stock is restored",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "const initial = parseInt(pm.environment.get('step11InitialStock'));",
                  "pm.test('Stock restored to initial level', () => {",
                  "  pm.expect(json.availableStock).to.equal(initial);",
                  "});",
                  "console.log('Expected stock:', initial, '| Actual stock:', json.availableStock);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api", "products", "{{productId}}"] }
          }
        },
        {
          "name": "2-6 Pay the CANCELLED order — 409",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409 — cannot pay a cancelled order', () => pm.response.to.have.status(409));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders/{{step11ExpiryOrderId}}/pay", "host": ["{{baseUrl}}"], "path": ["api", "orders", "{{step11ExpiryOrderId}}", "pay"] }
          }
        }
      ]
    },
    {
      "name": "3 — Race Guard: /pay beats expiry job",
      "description": "SETUP: pending-timeout-minutes=0 must still be active.\nCheckout, then pay IMMEDIATELY before the scheduler fires.\nScheduler should skip the order (rowsAffected=0 on cancelIfPending).",
      "item": [
        {
          "name": "3-1 Add item to cart (qty=1)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": {{productId}},\n  \"quantity\": 1\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/cart/items", "host": ["{{baseUrl}}"], "path": ["api", "cart", "items"] }
          }
        },
        {
          "name": "3-2 Checkout — creates PENDING order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Status is PENDING', () => pm.expect(json.status).to.equal('PENDING'));",
                  "pm.environment.set('step11PayRaceOrderId', json.id);",
                  "console.log('Pay-race order id:', json.id, '— run 3-3 immediately!');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders/checkout", "host": ["{{baseUrl}}"], "path": ["api", "orders", "checkout"] }
          }
        },
        {
          "name": "3-3 Pay immediately — wins the race",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 — payment accepted', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Status is PAID', () => pm.expect(json.status).to.equal('PAID'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders/{{step11PayRaceOrderId}}/pay", "host": ["{{baseUrl}}"], "path": ["api", "orders", "{{step11PayRaceOrderId}}", "pay"] }
          }
        },
        {
          "name": "⏳ WAIT 60-90s — confirm scheduler skipped this order",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "console.log('>>> PAUSE: wait 60-90s, then check Spring Boot logs for:');",
                  "console.log('    [Expiry] orderId=', pm.environment.get('step11PayRaceOrderId'), 'already paid or cancelled — skipping');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 404 expected — reminder step only."
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/wait-reminder-not-a-real-endpoint", "host": ["{{baseUrl}}"], "path": ["wait-reminder-not-a-real-endpoint"] }
          }
        },
        {
          "name": "3-4 Verify order is still PAID (scheduler did not cancel it)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Status is PAID — scheduler correctly skipped it', () => pm.expect(json.status).to.equal('PAID'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders/{{step11PayRaceOrderId}}", "host": ["{{baseUrl}}"], "path": ["api", "orders", "{{step11PayRaceOrderId}}"] }
          }
        },
        {
          "name": "3-5 Verify stock is NOT restored (legitimately sold)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "const initial = parseInt(pm.environment.get('step11InitialStock'));",
                  "pm.test('Stock is deducted (not restored) — order was paid', () => {",
                  "  pm.expect(json.availableStock).to.equal(initial - 1);",
                  "});",
                  "console.log('Expected (deducted):', initial - 1, '| Actual:', json.availableStock);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api", "products", "{{productId}}"] }
          }
        }
      ]
    },
    {
      "name": "4 — Race Guard: expiry job beats /pay",
      "description": "SETUP: pending-timeout-minutes=0 must still be active.\nCheckout, wait for scheduler to cancel it, then try to pay — should get 409.",
      "item": [
        {
          "name": "4-1 Add item to cart (qty=1)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": {{productId}},\n  \"quantity\": 1\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/cart/items", "host": ["{{baseUrl}}"], "path": ["api", "cart", "items"] }
          }
        },
        {
          "name": "4-2 Checkout — creates PENDING order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Status is PENDING', () => pm.expect(json.status).to.equal('PENDING'));",
                  "pm.environment.set('step11ExpiryRaceOrderId', json.id);",
                  "console.log('Expiry-race order id:', json.id, '— now WAIT 60-90s for expiry job to cancel it');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders/checkout", "host": ["{{baseUrl}}"], "path": ["api", "orders", "checkout"] }
          }
        },
        {
          "name": "⏳ WAIT 60-90s — let expiry job cancel the order",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "console.log('>>> PAUSE: wait 60-90s for scheduler to cancel order', pm.environment.get('step11ExpiryRaceOrderId'));",
                  "console.log('    Then run 4-3 and 4-4.');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 404 expected — reminder step only."
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/wait-reminder-not-a-real-endpoint", "host": ["{{baseUrl}}"], "path": ["wait-reminder-not-a-real-endpoint"] }
          }
        },
        {
          "name": "4-3 Verify order is CANCELLED",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Status is CANCELLED', () => pm.expect(json.status).to.equal('CANCELLED'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders/{{step11ExpiryRaceOrderId}}", "host": ["{{baseUrl}}"], "path": ["api", "orders", "{{step11ExpiryRaceOrderId}}"] }
          }
        },
        {
          "name": "4-4 Pay the CANCELLED order — 409 (expiry wins)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409 — expiry job won the race', () => pm.response.to.have.status(409));",
                  "const json = pm.response.json();",
                  "pm.test('Error message mentions status not PENDING', () => {",
                  "  pm.expect(json.error).to.include('PENDING');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders/{{step11ExpiryRaceOrderId}}/pay", "host": ["{{baseUrl}}"], "path": ["api", "orders", "{{step11ExpiryRaceOrderId}}", "pay"] }
          }
        },
        {
          "name": "4-5 Verify stock is restored (expiry job restored it)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "const initial = parseInt(pm.environment.get('step11InitialStock'));",
                  "pm.test('Stock restored after expiry cancellation', () => {",
                  "  // After folder 3 paid one unit, initial is already -1; expiry restores the folder 4 unit.",
                  "  // So we just verify stock went up by 1 vs what folder 3 left it at.",
                  "  pm.expect(json.availableStock).to.be.at.least(initial - 1);",
                  "});",
                  "console.log('Stock after expiry restore:', json.availableStock);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api", "products", "{{productId}}"] }
          }
        }
      ]
    }
  ]
}
