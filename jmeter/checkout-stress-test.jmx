        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="[setUp] Compute Stock Delta" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">
int initial = Integer.parseInt(vars.get(&quot;INITIAL_STOCK&quot;) ?: &quot;10&quot;)
int current = Integer.parseInt(vars.get(&quot;currentStock&quot;) ?: &quot;0&quot;)
int delta = initial - current
String reason = delta &gt;= 0 ? &quot;restock&quot; : &quot;correction&quot;
vars.put(&quot;stockDelta&quot;, String.valueOf(delta))
vars.put(&quot;stockReason&quot;, reason)
log.info(&quot;[setUp] currentStock=&quot; + current + &quot; target=&quot; + initial + &quot; delta=&quot; + delta + &quot; reason=&quot; + reason)
SampleResult.setResponseMessage(&quot;delta=&quot; + delta + &quot; reason=&quot; + reason)
SampleResult.setSuccessful(true)
          </stringProp>
        </JSR223Sampler>
