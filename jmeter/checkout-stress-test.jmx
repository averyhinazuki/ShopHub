        <IfController guiclass="IfControllerPanel" testclass="IfController" testname="[setUp] Skip PATCH if already at target" enabled="true">
          <stringProp name="IfController.condition">${__groovy(vars.get(&quot;stockDelta&quot;).toInteger() != 0,)}</stringProp>
          <boolProp name="IfController.evaluateAll">false</boolProp>
          <boolProp name="IfController.useExpression">true</boolProp>
        </IfController>
